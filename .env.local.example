# サイトの本番URL。metadataBase・OGP・sitemap/robots・ICSのUID等に使用。
# 本番(Vercel)では https://kanji-lab.com を設定してください。
NEXT_PUBLIC_APP_URL=http://localhost:3002

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# ホットペッパーグルメAPIキー（https://webservice.recruit.co.jp/register/ で取得）
HOTPEPPER_API_KEY=your_hotpepper_api_key_here

# 楽天ウェブサービス Application ID (https://webservice.rakuten.co.jp/)
# 楽天トラベルAPI(SimpleHotelSearch)で宿泊施設検索に使用
RAKUTEN_APPLICATION_ID=your_rakuten_application_id_here

# 楽天アフィリエイト(https://webservice.rakuten.co.jp/ でアフィリエイト登録後に取得)。
# 未設定の場合、宿泊施設リンクは通常URLのまま表示されます。
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id_here

# もしもアフィリエイト(https://af.moshimo.com/ で「ホットペッパーグルメ」
# プロモーションに提携申請後に取得)。3つとも未設定の場合、ホットペッパーの
# 予約・店舗リンクは通常URLのまま表示されます。
MOSHIMO_AFFILIATE_A_ID=your_a_id_here
MOSHIMO_AFFILIATE_P_ID=your_p_id_here
MOSHIMO_AFFILIATE_PL_ID=your_pl_id_here

# 開発時にAPIを節約したい場合は true にしてモックデータへ切り替え
NEXT_PUBLIC_USE_MOCK=false

# Google AdSense 審査通過後に true にすると広告枠(components/ads/AdSlot.tsx)が
# 表示されるようになる。審査中/未申請の間は false のままにしておく。
NEXT_PUBLIC_ADSENSE_ENABLED=false

# Anthropic Claude APIキー（https://console.anthropic.com/ で取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Analytics 4 測定ID（未設定の場合、計測タグは読み込まれません）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console の所有権確認コード（HTMLタグ確認方式で取得した
# content="..." の値）。ドメインごとに別のコードが発行されるため、
# kanji-lab.com プロパティ追加時にSearch Consoleで取得した値を設定してください。
# 未設定の場合、verification metaタグは出力されません。
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_code_here

# Resend APIキー（https://resend.com/api-keys で取得）。フィードバック送信
# （POST /api/feedback）に使用。未設定の場合、フィードバック送信APIはエラーを返します。
RESEND_API_KEY=your_resend_api_key_here

# フィードバックメールの送信元（Resendで検証済みドメインが未設定の場合は
# 未設定のままでOK。onboarding@resend.dev にフォールバックします）
RESEND_FROM_EMAIL=幹事ラボ <noreply@kanji-lab.com>

# ゲスト(匿名ユーザー)自動削除cron (GET /api/cron/cleanup-guests) の
# 認証シークレット。ランダムな文字列を設定し、Vercelの
# Project Settings > Environment Variables にも同じ値を登録してください。
# Vercel Cron はこの値を Authorization: Bearer ヘッダーに自動で付与します。
CRON_SECRET=your_random_secret_here
