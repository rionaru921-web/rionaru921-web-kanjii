NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here

# ホットペッパーグルメAPIキー（https://webservice.recruit.co.jp/register/ で取得）
HOTPEPPER_API_KEY=your_hotpepper_api_key_here

# 楽天ウェブサービス Application ID (https://webservice.rakuten.co.jp/)
# 楽天トラベルAPI(SimpleHotelSearch)で宿泊施設検索に使用
RAKUTEN_APPLICATION_ID=your_rakuten_application_id_here

# 開発時にAPIを節約したい場合は true にしてモックデータへ切り替え
NEXT_PUBLIC_USE_MOCK=false

# Anthropic Claude APIキー（https://console.anthropic.com/ で取得）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Analytics 4 測定ID（未設定の場合、計測タグは読み込まれません）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Resend APIキー（https://resend.com/api-keys で取得）。フィードバック送信
# （POST /api/feedback）に使用。未設定の場合、フィードバック送信APIはエラーを返します。
RESEND_API_KEY=your_resend_api_key_here

# フィードバックメールの送信元（Resendで検証済みドメインが未設定の場合は
# 未設定のままでOK。onboarding@resend.dev にフォールバックします）
RESEND_FROM_EMAIL=Kanjii <noreply@kanjii.app>

# ゲスト(匿名ユーザー)自動削除cron (GET /api/cron/cleanup-guests) の
# 認証シークレット。ランダムな文字列を設定し、Vercelの
# Project Settings > Environment Variables にも同じ値を登録してください。
# Vercel Cron はこの値を Authorization: Bearer ヘッダーに自動で付与します。
CRON_SECRET=your_random_secret_here
